# Local server secrets — copy to .env (which is git-ignored) and fill in.
# `npm run server` auto-loads .env via Node's --env-file-if-exists.
# In production these live in /etc/kpss-dashboard.env on the Pi (see deploy/DEPLOY.md).

# Enables the photo→topic AI (POST /api/classify). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model override (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite
